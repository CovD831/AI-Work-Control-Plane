#!/bin/bash
set -euo pipefail

repo_root=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
cd "$repo_root"

changed_args=()
has_compliance_input=0
while IFS= read -r -d '' file; do
    case "$file" in
        README.md|docs/process/*.md|docs/architecture/*.md|src/agent_orchestrator/*.py)
            has_compliance_input=1
            changed_args+=(--changed-file="$file")
            ;;
        *)
            continue
            ;;
    esac
done < <(git diff --cached --name-only -z --diff-filter=ACMR)

if [ "$has_compliance_input" -eq 0 ]; then
    exit 0
fi

if [ ! -f ".agent_orchestrator/hooks.json" ]; then
    echo "agent-orchestrator: managed hook marker missing; run python -m agent_orchestrator.cli install-hooks --root \"$repo_root\"" >&2
fi

PYTHONPATH=src python -m agent_orchestrator.cli team check-compliance "${changed_args[@]}"
